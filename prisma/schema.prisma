// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Field {
  id        String   @id @default(uuid())
  name      String
  type      String   // "5", "7", "11"
  price     Float
  imageUrl  String?
  availableDays String @default("Lunes,Martes,Miércoles,Jueves,Viernes,Sábado,Domingo") // Comma separated
  openTime  String     @default("09:00")
  closeTime String     @default("23:00")
  bookings  Booking[]
}

model Booking {
  id        String   @id @default(uuid())
  fieldId   String
  field     Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  date      DateTime
  startTime String   // e.g. "18:00"
  endTime   String   // e.g. "19:00"
  clientName String
  clientPhone String?
  totalPrice Float
  status    String   @default("pending") // pending, confirmed, cancelled
  createdAt DateTime @default(now())
}

model Account {
  id           String   @id @default(uuid())
  provider     String   @default("mercadopago")
  accessToken  String
  refreshToken String?
  publicKey    String?
  userId       String   @default("admin") // Simple single-user mapping
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
