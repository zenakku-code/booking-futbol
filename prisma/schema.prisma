// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Complex {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  address     String?
  logoUrl     String?
  
  // Payment Config
  downPaymentFixed   Float    @default(0)
  downPaymentEnabled Boolean  @default(false)
  
  // Subscription & Trial
  subscriptionActive Boolean  @default(true) // Start active (trial)
  trialEndsAt        DateTime?
  isActive           Boolean  @default(true) // For manual ban/disable
  subscriptionDate   DateTime?
  
  fields      Field[]
  accounts    Account[]
  users       User[]
  inventory   InventoryItem[]
  apiKeys     ApiKey[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Field {
  id            String    @id @default(uuid())
  name          String
  type          String    // "5", "7", "11"
  price         Float
  imageUrl      String?
  availableDays String    @default("Lunes,Martes,Miércoles,Jueves,Viernes,Sábado,Domingo")
  openTime      String    @default("09:00")
  closeTime     String    @default("23:00")
  bookings      Booking[]
  
  // SaaS Link
  complexId     String?
  complex       Complex?  @relation(fields: [complexId], references: [id])

  @@index([complexId])
}

model InventoryItem {
  id          String   @id @default(uuid())
  name        String
  price       Float    // Price per rental
  stock       Int      @default(0)
  
  complexId   String
  complex     Complex  @relation(fields: [complexId], references: [id])
  
  bookings    BookingItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([complexId])
}

model Booking {
  id          String   @id @default(uuid())
  fieldId     String
  field       Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  date        DateTime
  startTime   String   
  endTime     String   
  clientName  String
  clientPhone String?
  totalPrice  Float
  status      String   @default("pending") // pending, confirmed, confirmed_partial, cancelled, collecting
  
  // Payment Upgrade Phase 3
  paymentType String   @default("FULL") // FULL, SPLIT, DEPOSIT
  paidAmount  Float    @default(0)
  
  items       BookingItem[]
  payments    Payment[]
  
  createdAt   DateTime @default(now())

  @@index([fieldId])
  @@index([fieldId, date])
  @@index([status])
}

model Payment {
  id          String   @id @default(uuid())
  amount      Float
  status      String   @default("pending") // pending, approved, rejected
  externalId  String?  // MercadoPago Payment ID
  payerEmail  String?
  
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([bookingId])
  @@index([externalId])
}

// Join table for Booking and InventoryItem to track rented items per booking
model BookingItem {
  id              String        @id @default(uuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Int           @default(1)
  priceAtBooking  Float         // Snapshot of price when booked
  returned        Boolean       @default(false)

  @@index([bookingId])
  @@index([inventoryItemId])
}

model Account {
  id           String   @id @default(uuid())
  provider     String   @default("mercadopago")
  accessToken  String
  refreshToken String?
  publicKey    String?
  userId       String   @default("admin") 
  
  // SaaS Link
  complexId    String?   @unique
  complex      Complex?  @relation(fields: [complexId], references: [id])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([complexId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   
  role      String   @default("USER") // USER, ADMIN, SUPERADMIN
  
  // SaaS Link
  complexId String?
  complex   Complex? @relation(fields: [complexId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([complexId])
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  complexId String
  complex   Complex  @relation(fields: [complexId], references: [id])
  createdAt DateTime @default(now())
  lastUsed  DateTime?

  @@index([complexId])
}
