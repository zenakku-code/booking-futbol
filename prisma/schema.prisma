// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Complex {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  address     String?
  logoUrl     String?
  fields      Field[]
  accounts    Account[]
  users       User[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Field {
  id            String    @id @default(uuid())
  name          String
  type          String    // "5", "7", "11"
  price         Float
  imageUrl      String?
  availableDays String    @default("Lunes,Martes,Miércoles,Jueves,Viernes,Sábado,Domingo")
  openTime      String    @default("09:00")
  closeTime     String    @default("23:00")
  bookings      Booking[]
  
  // SaaS Link
  complexId     String?
  complex       Complex?  @relation(fields: [complexId], references: [id])
}

model Booking {
  id          String   @id @default(uuid())
  fieldId     String
  field       Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  date        DateTime
  startTime   String   
  endTime     String   
  clientName  String
  clientPhone String?
  totalPrice  Float
  status      String   @default("pending") 
  createdAt   DateTime @default(now())
}

model Account {
  id           String   @id @default(uuid())
  provider     String   @default("mercadopago")
  accessToken  String
  refreshToken String?
  publicKey    String?
  userId       String   @default("admin") 
  
  // SaaS Link
  complexId    String?   @unique
  complex      Complex?  @relation(fields: [complexId], references: [id])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   
  
  // SaaS Link
  complexId String?
  complex   Complex? @relation(fields: [complexId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
