model Complex {
  id                   String                @id @default(uuid())
  name                 String
  slug                 String                @unique
  address              String?
  description          String?
  logoUrl              String?
  // Payment Config
  downPaymentFixed     Float                 @default(0)
  downPaymentEnabled   Boolean               @default(false)
  // Subscription & Trial
  subscriptionActive   Boolean               @default(true) // Start active (trial)
  trialEndsAt          DateTime?
  isActive             Boolean               @default(true) // For manual ban/disable
  subscriptionDate     DateTime?
  subscriptionEndsAt   DateTime? // When the paid plan expires
  planType             String? // "MONTHLY" | "QUARTERLY"
  fields               Field[]
  accounts             Account[]
  users                User[]
  inventory            InventoryItem[]
  apiKeys              ApiKey[]
  subscriptionPayments SubscriptionPayment[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model SubscriptionPayment {
  id         String   @id @default(uuid())
  amount     Float
  planType   String // "MONTHLY" | "QUARTERLY"
  status     String   @default("pending") // pending, approved, rejected
  externalId String? // Payment provider ID (MP)
  complexId  String
  complex    Complex  @relation(fields: [complexId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([complexId])
}

model Field {
  id            String    @id @default(uuid())
  name          String
  type          String // "5", "7", "11"
  price         Float
  imageUrl      String?
  availableDays String    @default("Lunes,Martes,Miércoles,Jueves,Viernes,Sábado,Domingo")
  openTime      String    @default("09:00")
  closeTime     String    @default("23:00")
  bookings      Booking[]
  // SaaS Link
  complexId     String?
  complex       Complex?  @relation(fields: [complexId], references: [id])

  @@index([complexId])
}

model InventoryItem {
  id        String        @id @default(uuid())
  name      String
  price     Float // Price per rental
  stock     Int           @default(0)
  complexId String
  complex   Complex       @relation(fields: [complexId], references: [id])
  bookings  BookingItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([complexId])
}

model Booking {
  id          String        @id @default(uuid())
  fieldId     String
  field       Field         @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  date        DateTime
  startTime   String
  endTime     String
  clientName  String
  clientPhone String?
  totalPrice  Float
  status      String        @default("pending") // pending, confirmed, confirmed_partial, cancelled, collecting
  // Payment Upgrade Phase 3
  paymentType String        @default("FULL") // FULL, SPLIT, DEPOSIT
  paidAmount  Float         @default(0)
  items       BookingItem[]
  payments    Payment[]
  createdAt   DateTime      @default(now())

  @@index([fieldId])
  @@index([fieldId, date])
  @@index([status])
}

model Payment {
  id         String   @id @default(uuid())
  amount     Float
  status     String   @default("pending") // pending, approved, rejected
  externalId String? // MercadoPago Payment ID
  payerEmail String?
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([bookingId])
  @@index([externalId])
}

// Join table for Booking and InventoryItem to track rented items per booking

model BookingItem {
  id              String        @id @default(uuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Int           @default(1)
  priceAtBooking  Float // Snapshot of price when booked
  returned        Boolean       @default(false)

  @@index([bookingId])
  @@index([inventoryItemId])
}

model Account {
  id           String   @id @default(uuid())
  provider     String   @default("mercadopago")
  accessToken  String
  refreshToken String?
  publicKey    String?
  userId       String   @default("admin") // SaaS Link
  complexId    String?  @unique
  complex      Complex? @relation(fields: [complexId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([complexId])
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  emailVerified Boolean  @default(false)
  image         String?
  password      String?
  role          String   @default("USER") // USER, ADMIN, SUPERADMIN
  // SaaS Link
  complexId     String?
  complex       Complex? @relation(fields: [complexId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Better Auth Relations
  sessions Session[]
  accounts AuthAccount[]

  @@index([complexId])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model AuthAccount {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("auth_account")
  @@index([userId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model ApiKey {
  id        String    @id @default(uuid())
  key       String    @unique
  name      String
  complexId String
  complex   Complex   @relation(fields: [complexId], references: [id])
  createdAt DateTime  @default(now())
  lastUsed  DateTime?

  @@index([complexId])
}

model SystemConfig {
  id             String   @id @default(uuid())
  monthlyPrice   Float    @default(10000)
  quarterlyPrice Float    @default(27000)
  annualPrice    Float    @default(100000)
  updatedAt      DateTime @updatedAt
}
